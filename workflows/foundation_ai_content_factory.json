      "name": "Parse Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [220, 300]
    },
    {
      "parameters": {
        "command": "=node \"{{ $env.SCRIPT_DIR || '/data/ai-content-factory' }}/scripts/format_text.js\" {{ $json.url ? '--url \"' + $json.url + '\"' : '' }} {{ $json.text ? '--text \"' + $json.text.replace(/\"/g, '\\\\\"') + '\"' : '' }}"
      },
      "id": "a1b2c3d4-0003-4000-8000-000000000003",
      "name": "Format Text",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [440, 300]
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.stdout || '{}';\nlet data;\ntry { data = JSON.parse(raw.trim()); } catch (e) { throw new Error('format_text parse: ' + raw.slice(0, 200)); }\nif (!data.ok) throw new Error(data.error || 'format_text failed');\nreturn [{ json: data }];"
      },
      "id": "a1b2c3d4-0004-4000-8000-000000000004",
      "name": "Parse Format",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [660, 300]
    },
    {
      "parameters": {
        "command": "=node \"{{ $env.SCRIPT_DIR || '/data/ai-content-factory' }}/scripts/gemini_cached.js\" --input \"{{ $json.text.replace(/\"/g, '\\\\\"').replace(/\\n/g, ' ') }}\""
      },
      "id": "a1b2c3d4-0005-4000-8000-000000000005",
      "name": "Gemini Cached",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [880, 300]
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.stdout || '{}';\nlet data;\ntry { data = JSON.parse(raw.trim()); } catch (e) { throw new Error('gemini parse: ' + raw.slice(0, 200)); }\nif (!data.ok) throw new Error(data.error || 'gemini failed');\nconst theses = Array.isArray(data.theses) ? data.theses : [];\nconst caption = [\n  data.short_post,\n  '',\n  '📌 Тези:',\n  ...theses.map(t => '• ' + t),\n  '',\n  '💬 Експерт:',\n  data.expert_opinion\n].join('\\n');\nconst imagePrompt = (data.short_post || 'ukrainian social media').slice(0, 400);\nreturn [{ json: { ...data, caption, imagePrompt, imageUrl: 'https://image.pollinations.ai/prompt/' + encodeURIComponent(imagePrompt) + '?width=1024&height=1024&nologo=true' } }];"
      },
