    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst url = (body.url || '').trim();\nconst text = (body.text || '').trim();\nif (!url && !text) throw new Error('Потрібно url або text');\nreturn [{ json: { url, text } }];"
      },
